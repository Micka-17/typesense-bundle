{% extends '@Micka17Typesense/base.html.twig' %}

{% block title %}Dashboard — Typesense Admin{% endblock %}

{% block body %}
<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
        <small class="text-muted">Vue d'ensemble de votre instance Typesense</small>
    </div>
    {% if health.ok is defined %}
        <span class="badge bg-{{ health.ok ? 'success' : 'danger' }} fs-6 px-3 py-2">
            <i class="bi bi-{{ health.ok ? 'check-circle' : 'x-circle' }}"></i>
            {{ health.ok ? 'Healthy' : 'Unhealthy' }}
        </span>
    {% else %}
        <span class="badge bg-secondary fs-6 px-3 py-2"><i class="bi bi-question-circle"></i> Non joignable</span>
    {% endif %}
</div>

<div class="p-4">
    {# ── Resource counts ── #}
    <div class="row g-3 mb-4">
        {% set tiles = [
            {key: 'collections',   label: 'Collections',   icon: 'bi-collection',       route: 'collections',      color: 'primary'},
            {key: 'presets',       label: 'Presets',       icon: 'bi-sliders',          route: 'presets',          color: 'secondary'},
            {key: 'synonym_sets',  label: 'Synonym Sets',  icon: 'bi-arrow-left-right', route: 'synonym-sets',     color: 'info'},
            {key: 'curation_sets', label: 'Curation Sets', icon: 'bi-funnel',           route: 'curation-sets',    color: 'warning'},
            {key: 'stemming',      label: 'Stemming',      icon: 'bi-tree',             route: 'stemming',         color: 'success'},
            {key: 'analytics',     label: 'Analytics',     icon: 'bi-bar-chart-line',   route: 'analytics',        color: 'danger'},
            {key: 'nl_search',     label: 'NL Search',     icon: 'bi-translate',        route: 'nl-search-models', color: 'dark'},
            {key: 'conversations', label: 'Conversations', icon: 'bi-chat-dots',        route: 'conversations',    color: 'secondary'},
            {key: 'aliases',       label: 'Aliases',       icon: 'bi-link-45deg',       route: 'aliases',          color: 'primary'},
            {key: 'keys',          label: 'API Keys',      icon: 'bi-key',              route: 'keys',             color: 'dark'},
        ] %}
        {% for t in tiles %}
        <div class="col-6 col-sm-4 col-xl-3">
            <a href="{{ path('micka17_typesense_admin_resource_list', {resource: t.route}) }}" class="text-decoration-none">
                <div class="stat-card h-100 transition">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <i class="bi {{ t.icon }} text-{{ t.color }}"></i>
                        <span class="stat-label">{{ t.label }}</span>
                    </div>
                    <div class="stat-value">{{ counts[t.key] ?? 0 }}</div>
                </div>
            </a>
        </div>
        {% endfor %}
    </div>

    {# ── Collections quick view ── #}
    {% if collections|length > 0 %}
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-collection me-1"></i> Collections ({{ collections|length }})</span>
            <a href="{{ path('micka17_typesense_admin_resource_list', {resource: 'collections'}) }}" class="btn btn-sm btn-outline-secondary">Tout voir</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th class="text-end">Documents</th>
                        <th class="text-end">Champs</th>
                        <th class="text-end">Créée le</th>
                    </tr>
                </thead>
                <tbody>
                {% for col in collections|slice(0, 8) %}
                    <tr>
                        <td><code class="text-primary">{{ col.name }}</code></td>
                        <td class="text-end"><span class="badge bg-primary rounded-pill">{{ col.num_documents|number_format }}</span></td>
                        <td class="text-end text-muted">{{ col.fields|length }}</td>
                        <td class="text-end text-muted small">
                            {% if col.created_at is defined %}{{ (col.created_at)|date('d/m/Y') }}{% else %}—{% endif %}
                        </td>
                    </tr>
                {% endfor %}
                {% if collections|length > 8 %}
                    <tr><td colspan="4" class="text-center text-muted small py-2">+ {{ collections|length - 8 }} de plus…</td></tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i>
        Aucune collection. Lancez <code>micka17:typesense:sync</code> pour créer les collections.
    </div>
    {% endif %}
</div>
{% endblock %}
