<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Typesense Admin{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔍</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #f5f6fa; }
        .ts-sidebar { width: 230px; min-height: 100vh; background: #12122a; flex-shrink: 0; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
        .ts-sidebar .brand { color: #fff; font-weight: 600; font-size: 1rem; padding: 1rem 1.25rem .75rem; border-bottom: 1px solid rgba(255,255,255,.07); }
        .ts-sidebar .section-label { font-size: .65rem; font-weight: 700; letter-spacing: .1em; color: #6c757d; text-transform: uppercase; padding: .9rem 1.25rem .2rem; }
        .ts-sidebar .nav-link { color: #9ca3af; padding: .35rem 1.1rem; border-radius: .375rem; margin: 1px 8px; font-size: .83rem; display: flex; align-items: center; gap: .5rem; }
        .ts-sidebar .nav-link i { font-size: .95rem; flex-shrink: 0; }
        .ts-sidebar .nav-link:hover { background: rgba(255,255,255,.07); color: #e5e7eb; }
        .ts-sidebar .nav-link.active { background: rgba(99,102,241,.25); color: #a5b4fc; }
        .ts-main { flex: 1; min-width: 0; }
        .page-header { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1rem 1.5rem; }
        .page-header h1 { font-size: 1.25rem; font-weight: 600; margin: 0; }
        .stat-card { background: #fff; border-radius: .5rem; border: 1px solid #e5e7eb; padding: 1.1rem 1.25rem; }
        .stat-card .stat-value { font-size: 1.6rem; font-weight: 700; }
        .stat-card .stat-label { font-size: .8rem; color: #6b7280; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<div class="d-flex">
    <nav class="ts-sidebar d-flex flex-column">
        <a class="brand text-decoration-none d-flex align-items-center gap-2" href="{{ path('micka17_typesense_admin_dashboard') }}">
            <i class="bi bi-search-heart text-indigo"></i> Typesense
        </a>

        <div class="section-label">Vue d'ensemble</div>
        <a class="nav-link {% if app.request.attributes.get('_route') == 'micka17_typesense_admin_dashboard' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_dashboard') }}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'collections' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'collections'}) }}">
            <i class="bi bi-collection"></i> Collections
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'aliases' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'aliases'}) }}">
            <i class="bi bi-link-45deg"></i> Aliases
        </a>

        <div class="section-label">Recherche</div>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'presets' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'presets'}) }}">
            <i class="bi bi-sliders"></i> Presets
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'synonym-sets' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'synonym-sets'}) }}">
            <i class="bi bi-arrow-left-right"></i> Synonym Sets
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'curation-sets' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'curation-sets'}) }}">
            <i class="bi bi-funnel"></i> Curation Sets
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'stemming' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'stemming'}) }}">
            <i class="bi bi-tree"></i> Stemming
        </a>

        <div class="section-label">IA & Analytics</div>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'nl-search-models' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'nl-search-models'}) }}">
            <i class="bi bi-translate"></i> NL Search
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'conversations' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'conversations'}) }}">
            <i class="bi bi-chat-dots"></i> Conversations
        </a>
        <a class="nav-link {% if app.request.attributes.get('resource') == 'analytics' %}active{% endif %}"
           href="{{ path('micka17_typesense_admin_resource_list', {resource: 'analytics'}) }}">
            <i class="bi bi-bar-chart-line"></i> Analytics
        </a>
    </nav>

    <div class="ts-main">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'info')) }} alert-dismissible fade show m-3 mb-0" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmzOA3xEXSCEXTD9Pox7v3/2UG" crossorigin="anonymous"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
