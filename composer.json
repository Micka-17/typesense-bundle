{
    "name": "micka-17/typesense-bundle",
    "description": "Un bundle Symfony pour intégrer Typesense.",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Mickaël",
            "email": "mickaelboi.dev@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/framework-bundle": "^7.4 || ^8.0",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/console": "^7.4 || ^8.0",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-bundle": "^2.14 || ^3.0",
        "typesense/typesense-php": "^6.0",
        "symfony/http-client": "^7.4 || ^8.0",
        "symfony/messenger": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "symfony/phpunit-bridge": "^7.4 || ^8.0",
        "phpstan/phpstan": "^2.1",
        "phpspec/prophecy-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Micka17\\TypesenseBundle\\": "src/",
            "Micka17\\TypesenseBundle\\Tests\\": "tests/",
            "Typesense\\": "vendor/typesense/typesense-php/src/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse",
        "validate-config": "composer validate --strict"
    }
}
